<%- include('../partials/head') %>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo-circle">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h1 class="auth-title">¿Olvidaste tu contraseña?</h1>
      <p class="auth-sub">Te enviaremos un enlace para restablecerla</p>
    </div>

    <% if (flash?.error) { %>
      <div class="flash flash-error"><%= flash.error %></div>
    <% } %>
    <% if (flash?.success) { %>
      <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <form action="/auth/olvide-contrasena" method="POST" class="auth-form">
      <div class="form-group">
        <label class="form-label">Correo electrónico</label>
        <input type="email" name="email" class="form-input"
               placeholder="tucorreo@empresa.com" required autocomplete="email" autofocus>
        <small class="form-hint">Ingresa el correo con el que te registraste.</small>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Enviar enlace de recuperación</button>
    </form>

    <p class="auth-footer-link">
      <a href="/auth/login">← Volver a iniciar sesión</a>
    </p>
  </div>
</div>
<script src="/js/main.js"></script>
</body></html>
