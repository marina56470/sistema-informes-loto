<%- include('../partials/head') %>
<div class="auth-page">
  <div class="auth-card">

    <% if (!tokenValido) { %>
      <!-- ── TOKEN INVÁLIDO O EXPIRADO ── -->
      <div class="auth-header">
        <div class="auth-logo-circle" style="font-size:1.6rem;">⏱️</div>
        <h1 class="auth-title">Enlace expirado</h1>
        <p class="auth-sub">Este enlace ya no es válido</p>
      </div>
      <p style="text-align:center;color:#555;font-size:.85rem;line-height:1.7;margin-bottom:1.5rem;">
        El enlace de recuperación expiró o ya fue utilizado. Por seguridad, estos enlaces
        solo funcionan durante <strong>1 hora</strong>. Solicita uno nuevo.
      </p>
      <a href="/auth/olvide-contrasena" class="btn btn-primary btn-block">Solicitar nuevo enlace</a>
      <p class="auth-footer-link">
        <a href="/auth/login">← Volver a iniciar sesión</a>
      </p>

    <% } else { %>
      <!-- ── FORMULARIO DE NUEVA CONTRASEÑA ── -->
      <div class="auth-header">
        <div class="auth-logo-circle">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="auth-title">Nueva Contraseña</h1>
        <p class="auth-sub">Crea una contraseña segura para tu cuenta</p>
      </div>

      <% if (flash?.error) { %>
        <div class="flash flash-error"><%= flash.error %></div>
      <% } %>

      <form action="/auth/restablecer/<%= token %>" method="POST" class="auth-form" id="reset-form">
        <div class="form-group">
          <label class="form-label">Nueva contraseña</label>
          <input type="password" name="password" id="pw1" class="form-input"
                 placeholder="••••••••" required minlength="8" autocomplete="new-password" autofocus>
          <div class="pw-strength" id="pw-strength" style="display:none;">
            <div class="pw-strength-bar"><div class="pw-strength-fill" id="pw-strength-fill"></div></div>
            <span class="pw-strength-text" id="pw-strength-text"></span>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Confirmar nueva contraseña</label>
          <input type="password" name="password2" id="pw2" class="form-input"
                 placeholder="••••••••" required autocomplete="new-password">
          <small class="form-hint" id="pw-match-hint" style="display:none;"></small>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Restablecer contraseña</button>
      </form>

      <p class="auth-footer-link">
        <a href="/auth/login">← Cancelar e ir al login</a>
      </p>
    <% } %>

  </div>
</div>

<% if (tokenValido) { %>
<script>
const pw1 = document.getElementById('pw1');
const pw2 = document.getElementById('pw2');
const strengthWrap = document.getElementById('pw-strength');
const strengthFill = document.getElementById('pw-strength-fill');
const strengthText = document.getElementById('pw-strength-text');
const matchHint     = document.getElementById('pw-match-hint');

function evaluarFuerza(pw) {
  let score = 0;
  if (pw.length >= 8)  score++;
  if (pw.length >= 12) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  return score; // 0-5
}

pw1.addEventListener('input', () => {
  const val = pw1.value;
  if (!val) { strengthWrap.style.display = 'none'; return; }
  strengthWrap.style.display = 'flex';

  const score = evaluarFuerza(val);
  const niveles = [
    { pct: 20,  color: '#D32F2F', text: 'Muy débil' },
    { pct: 40,  color: '#E65100', text: 'Débil' },
    { pct: 60,  color: '#F5C800', text: 'Aceptable' },
    { pct: 80,  color: '#7CB342', text: 'Buena' },
    { pct: 100, color: '#1B5E20', text: 'Excelente' },
  ];
  const nivel = niveles[Math.min(score, 4)];
  strengthFill.style.width = nivel.pct + '%';
  strengthFill.style.background = nivel.color;
  strengthText.textContent = nivel.text;
  strengthText.style.color = nivel.color;

  checkMatch();
});

pw2.addEventListener('input', checkMatch);

function checkMatch() {
  if (!pw2.value) { matchHint.style.display = 'none'; return; }
  matchHint.style.display = 'block';
  if (pw1.value === pw2.value) {
    matchHint.textContent = '✓ Las contraseñas coinciden';
    matchHint.style.color = '#1B5E20';
  } else {
    matchHint.textContent = '✕ Las contraseñas no coinciden';
    matchHint.style.color = '#D32F2F';
  }
}
</script>
<style>
.pw-strength { display:flex; align-items:center; gap:.5rem; margin-top:.4rem; }
.pw-strength-bar { flex:1; height:5px; background:var(--gray-200); border-radius:3px; overflow:hidden; }
.pw-strength-fill { height:100%; width:0%; border-radius:3px; transition:width .2s, background .2s; }
.pw-strength-text { font-size:.68rem; font-weight:700; white-space:nowrap; }
</style>
<% } %>

<script src="/js/main.js"></script>
</body></html>
