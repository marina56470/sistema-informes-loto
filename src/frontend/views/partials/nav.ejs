<nav class="navbar">
  <a href="/dashboard" class="nav-brand">
    <!-- Logo: muestra imagen si existe, si no el círculo amarillo fallback -->
    <div class="nav-logo-img-wrap">
      <img src="/img/logo.png" alt="Logo" class="nav-logo-img"
           onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'">
      <div class="nav-logo-circle" style="display:none;">Y</div>
    </div>
    <div class="nav-logo-text">
      <span class="nav-logo-main">LOTO PRO</span>
      <span class="nav-logo-sub">ASSA ABLOY</span>
    </div>
  </a>

  <div class="nav-links" id="navLinks">
    <a href="/dashboard"  class="nav-link <%= title==='Inicio'    ? 'active':'' %>">Inicio</a>
    <a href="/informes"   class="nav-link <%= title==='Mis Informes' ? 'active':'' %>">Informes</a>
    <a href="/clientes"   class="nav-link <%= title==='Clientes'     ? 'active':'' %>">Clientes</a>
    <a href="/productos"  class="nav-link <%= ['Catálogo Yale','Nuevo Producto','Editar Producto'].includes(title) ? 'active':'' %>">Catálogo</a>

    <!-- En móvil, el usuario y logout viven dentro del mismo menú desplegable -->
    <div class="nav-mobile-user">
      <div class="nav-mobile-user-row">
        <% if (user?.avatar_url) { %>
          <img src="<%= user.avatar_url %>" alt="Avatar" class="nav-avatar">
        <% } else { %>
          <div class="nav-avatar-placeholder"><%= user?.nombre?.charAt(0).toUpperCase() || 'U' %></div>
        <% } %>
        <div class="nav-user-info">
          <span class="nav-user-name"><%= user?.nombre || 'Usuario' %></span>
          <span class="nav-user-zona"><%= user?.zona || user?.cargo || '' %></span>
        </div>
      </div>
      <a href="/auth/logout" class="nav-link nav-mobile-logout">⏻ Cerrar sesión</a>
    </div>
  </div>

  <!-- Botón hamburguesa: solo visible en móvil. onclick directo, sin
       intermediarios, es el método más confiable entre navegadores. -->
  <button type="button" class="nav-burger" id="navBurger" aria-label="Abrir menú"
          aria-expanded="false" onclick="window.lotoToggleMenu()">
    <span></span><span></span><span></span>
  </button>

  <div class="nav-user">
    <% if (user?.avatar_url) { %>
      <img src="<%= user.avatar_url %>" alt="Avatar" class="nav-avatar">
    <% } else { %>
      <div class="nav-avatar-placeholder"><%= user?.nombre?.charAt(0).toUpperCase() || 'U' %></div>
    <% } %>
    <div class="nav-user-info">
      <span class="nav-user-name"><%= user?.nombre || 'Usuario' %></span>
      <span class="nav-user-zona"><%= user?.zona || user?.cargo || '' %></span>
    </div>
    <a href="/auth/logout" class="nav-logout" title="Cerrar sesión">⏻</a>
  </div>
</nav>

<!-- FLASH MESSAGES -->
<% if (flash?.success) { %>
  <div class="flash flash-success"><%= flash.success %></div>
<% } %>
<% if (flash?.error) { %>
  <div class="flash flash-error"><%= flash.error %></div>
<% } %>

<script>
  // IMPORTANTE: ya no usamos un <div> de overlay separado. Antes, ese div
  // cubría toda la pantalla (position:fixed; inset:0) y, sin importar el
  // z-index, en la práctica terminaba capturando los clics destinados a
  // los links del menú — confirmado con DevTools, el clic caía en
  // #navOverlay en vez de en el <a>. El fondo oscuro ahora es un
  // pseudo-elemento ::before generado por CSS dentro del propio <nav>,
  // que nunca puede "tapar" al menú porque es parte del mismo árbol y
  // queda automáticamente detrás en el z-index.
  window.lotoToggleMenu = function() {
    const links = document.getElementById('navLinks');
    const burger = document.getElementById('navBurger');
    const isOpen = links.classList.contains('nav-links-open');
    if (isOpen) {
      window.lotoCloseMenu();
    } else {
      links.classList.add('nav-links-open');
      document.body.classList.add('nav-menu-open');
      burger.classList.add('nav-burger-open');
      burger.setAttribute('aria-expanded', 'true');
    }
  };

  window.lotoCloseMenu = function() {
    const links = document.getElementById('navLinks');
    const burger = document.getElementById('navBurger');
    links.classList.remove('nav-links-open');
    document.body.classList.remove('nav-menu-open');
    burger.classList.remove('nav-burger-open');
    burger.setAttribute('aria-expanded', 'false');
  };

  // Cerrar al tocar/clickear fuera del menú: revisamos en la fase de
  // captura (capture:true) si el clic NO fue dentro de #navLinks ni en
  // el botón hamburguesa. Esto reemplaza al overlay como mecanismo de
  // "cerrar tocando afuera", sin necesitar ningún elemento adicional
  // que pueda interponerse.
  document.addEventListener('click', function(e) {
    const links = document.getElementById('navLinks');
    if (!links || !links.classList.contains('nav-links-open')) return;
    if (e.target.closest('#navLinks') || e.target.closest('#navBurger')) return;
    window.lotoCloseMenu();
  }, true);
</script>
