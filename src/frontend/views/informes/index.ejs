<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<main class="page-content">
  <div class="page-header">
    <div>
      <h1 class="page-title"><span class="title-dot"></span>Mis Informes</h1>
      <p class="page-sub"><%= total %> informe<%= total !== 1 ? 's' : '' %> encontrado<%= total !== 1 ? 's' : '' %></p>
    </div>
    <a href="/informes/nuevo" class="btn btn-primary">+ Nuevo Informe</a>
  </div>

  <!-- Filtros -->
  <form method="GET" action="/informes" class="filter-bar">
    <input type="text" name="q" value="<%= filtros.q || '' %>" placeholder="Buscar empresa..." class="form-input filter-input">
    <select name="estado" class="form-input filter-select">
      <option value="">Todos los estados</option>
      <option value="borrador"   <%= filtros.estado==='borrador'   ? 'selected':'' %>>Borrador</option>
      <option value="finalizado" <%= filtros.estado==='finalizado' ? 'selected':'' %>>Finalizado</option>
      <option value="enviado"    <%= filtros.estado==='enviado'    ? 'selected':'' %>>Enviado</option>
    </select>
    <button type="submit" class="btn btn-outline">Filtrar</button>
    <a href="/informes" class="btn btn-ghost">Limpiar</a>
  </form>

  <% if (!informes.length) { %>
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <p>No se encontraron informes. <a href="/informes/nuevo">Crea uno nuevo</a>.</p>
    </div>
  <% } else { %>
    <div class="informes-grid">
      <% informes.forEach(inf => { %>
        <div class="informe-card">
          <div class="ic-header">
            <span class="ic-estado ic-estado-<%= inf.estado %>"><%= inf.estado %></span>
            <span class="ic-fecha"><%= new Date(inf.fecha_informe).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'}) %></span>
          </div>
          <div class="ic-body">
            <div class="ic-empresa"><%= inf.empresa || '— Sin cliente —' %></div>
            <% if (inf.ciudad) { %><div class="ic-ciudad">📍 <%= inf.ciudad %></div><% } %>
            <div class="ic-hallazgos">🔒 <%= inf.total_hallazgos %> punto<%= inf.total_hallazgos != 1 ? 's' : '' %> de bloqueo</div>
          </div>
          <div class="ic-footer">
            <a href="/informes/<%= inf.id %>/editar"  class="btn btn-sm btn-outline">✏️ Editar</a>
            <a href="/informes/<%= inf.id %>/preview" class="btn btn-sm btn-primary">👁 Ver</a>
            <form action="/informes/<%= inf.id %>/delete" method="POST" onsubmit="return confirm('¿Eliminar este informe y todos sus puntos de bloqueo?')">
              <button type="submit" class="btn btn-sm btn-danger">🗑</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <!-- Paginación -->
    <% if (paginas > 1) { %>
      <div class="pagination">
        <% for(let p = 1; p <= paginas; p++) { %>
          <a href="/informes?page=<%= p %>&estado=<%= filtros.estado||'' %>&q=<%= filtros.q||'' %>"
             class="page-btn <%= p === paginaActual ? 'active' : '' %>"><%= p %></a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</main>

<%- include('../partials/footer') %>
