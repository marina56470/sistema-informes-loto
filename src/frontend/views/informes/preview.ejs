<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<% const ENERGIAS_STYLE = {
  'Eléctrica':  'background:#FFF8E1;color:#E65100',
  'Mecánica':   'background:#F3E5F5;color:#6A1B9A',
  'Neumática':  'background:#E8F5E9;color:#1B5E20',
  'Hidráulica': 'background:#E3F2FD;color:#0D47A1',
  'Térmica':    'background:#FBE9E7;color:#BF360C',
  'Química':    'background:#FFEBEE;color:#B71C1C',
}; %>

<% function fmtFecha(d) {
  if (!d) return '—';
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const dt = new Date(d);
  return `${dt.getDate()} de ${meses[dt.getMonth()]} ${dt.getFullYear()}`;
} %>

<main class="page-content no-print-padding">

  <!-- Barra de acciones (no imprime) -->
  <div class="preview-actions no-print">
    <div>
      <h1 class="page-title"><span class="title-dot"></span>Vista Previa</h1>
      <p class="page-sub"><%= informe.empresa || 'Sin cliente' %></p>
    </div>
    <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
      <a href="/informes/<%= informe.id %>/editar" class="btn btn-outline"> Editar</a>
      <% if (informe.estado === 'borrador') { %>
        <form action="/informes/<%= informe.id %>/finalizar" method="POST" style="display:inline">
          <button type="submit" class="btn btn-outline">Finalizar</button>
        </form>
      <% } %>
      <button onclick="window.print()" class="btn btn-outline">🖨 Imprimir / PDF</button>
      <button onclick="abrirModalEnvio()" class="btn btn-send">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        Enviar por correo
      </button>
    </div>
  </div>

  <!-- ══ REPORTE IMPRIMIBLE ══════════════════════════════════════════════════ -->
  <div class="report-page" id="reportePage">

    <!-- Encabezado -->
    <div class="report-header">
      <div>
        <div class="report-header-logo">ASSA ABLOY</div>
        <div style="color:rgba(255,255,255,0.7);font-size:0.65rem;letter-spacing:1px;margin-top:2px;">COLOMBIA S.A.S.</div>
      </div>
      <div class="report-header-company">
        <h2>INFORME DE CONTROL DE ENERGÍAS PELIGROSAS</h2>
        <p>Bloqueo y Etiquetado — Yale</p>
      </div>
    </div>

    <!-- Carta -->
    <div class="report-cover">
      <div class="report-date">Barranquilla, <%= fmtFecha(informe.fecha_informe) %></div>
      <div class="report-recipient">
        <p>Señores</p>
        <p><strong><%= informe.empresa || 'EMPRESA CLIENTE' %></strong></p>
        <% if (informe.contacto) { %><p>Atn. <%= informe.contacto %><%= informe.cargo_contacto ? ' — '+informe.cargo_contacto : '' %></p><% } %>
        <% if (informe.ciudad) { %><p><%= informe.ciudad %></p><% } %>
        <br><p>Respetados Señores.</p>
      </div>

      <p class="report-body-text">ASSA ABLOY COLOMBIA, en su compromiso continuo con el fortalecimiento de la cultura de seguridad industrial y la optimización de los procesos operativos de sus clientes, desarrolla e implementa soluciones técnicas orientadas al control efectivo de energías peligrosas en entornos industriales.</p>

      <% if (informe.fecha_visita) { %>
        <p class="report-body-text">En ese contexto, el pasado <strong><%= fmtFecha(informe.fecha_visita) %></strong> se llevó a cabo una visita técnica a las instalaciones de <strong><%= informe.empresa %></strong>, donde se realizó un recorrido exhaustivo por las diferentes áreas operativas. Durante esta intervención, se identificaron y caracterizaron las fuentes de energías peligrosas asociadas a los equipos y máquinas en funcionamiento.</p>
      <% } %>

      <p class="report-body-text">El presente informe tiene como objetivo documentar las energías peligrosas presentes en su planta y recomendar los dispositivos de bloqueo y etiquetado requeridos para cada punto de intervención.</p>
    </div>

    <!-- Tabla de hallazgos -->
    <div class="report-section-title">
      INFORME DE RECORRIDO — <%= (informe.empresa || '').toUpperCase() %> <%= informe.ciudad ? '— '+informe.ciudad.toUpperCase() : '' %>
    </div>
    <div class="report-table-wrap">
      <table class="report-table">
        <thead>
          <tr>
            <th>PROCESO</th>
            <th>ÁREA</th>
            <th>HALLAZGOS</th>
            <th>ENERGÍAS PELIGROSAS</th>
            <th>REGISTRO FOTOGRÁFICO</th>
            <th>RECOMENDACIONES</th>
          </tr>
        </thead>
        <tbody>
          <% if (!hallazgos.length) { %>
            <tr><td colspan="6" style="text-align:center;padding:20px;color:#999;">Sin hallazgos registrados</td></tr>
          <% } %>
          <% hallazgos.forEach(h => {
            const energias = typeof h.energias === 'string' ? JSON.parse(h.energias) : h.energias;
            const prods    = typeof h.productos === 'string' ? JSON.parse(h.productos) : h.productos;
          %>
            <tr>
              <td style="width:120px;text-align:center;"><div class="rt-process"><%= h.proceso || '—' %></div></td>
              <td style="width:130px;font-weight:600;"><%= h.area %></td>
              <td><div class="rt-finding"><%= h.descripcion %></div></td>
              <td style="width:120px;">
                <% energias.forEach(e => { %>
                  <span class="rt-energy-pill" style="<%= ENERGIAS_STYLE[e] || '' %>"><%= e %></span>
                <% }) %>
              </td>
              <td class="rt-photo-cell">
                <% if (h.foto_path) { %>
                  <img src="<%= h.foto_path %>" alt="Punto de bloqueo">
                <% } else { %>
                  <div class="rt-photo-placeholder">📷 Sin foto</div>
                <% } %>
              </td>
              <td>
                <% prods.forEach(p => { %>
                  <div class="rt-product-block">
                    <% if (p.foto_url) { %>
                      <div class="rt-product-foto-wrap">
                        <img src="<%= p.foto_url %>" alt="<%= p.nombre %>" class="rt-product-foto">
                      </div>
                    <% } %>
                    <div class="rt-product-text">
                      <div class="rt-sku">SKU <%= p.sku %></div>
                      <div class="rt-product-name"><%= p.nombre %></div>
                    </div>
                  </div>
                <% }) %>
                <% if (h.recomendaciones) { %>
                  <div style="margin-top:6px;font-size:0.7rem;color:#444;padding:4px 6px;background:#fffde7;border-left:2px solid #F5C800;">
                    <strong>Nota:</strong> <%= h.recomendaciones %>
                  </div>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Notas técnicas -->
    <div class="report-notes">
      <h3>NOTAS TÉCNICAS ADICIONALES</h3>
      <ol>
        <li>Los dispositivos sugeridos corresponden a la recomendación de ASSA ABLOY COLOMBIA. La responsabilidad final de selección e implementación es de <strong><%= informe.empresa || 'la empresa cliente' %></strong>.</li>
        <li>Todos los dispositivos deberán ser asegurados con candados. Para bloqueo eléctrico: candados nylon dieléctricos; para bloqueo mecánico: candados con gancho metálico o nylon.</li>
        <li>Para tableros de control y potencia se recomienda el uso de dispositivos de bloqueo múltiple (SKU 0016016, 0001171, 0009711) y estaciones de bloqueo (SKU 0001170).</li>
        <li>Los dispositivos asegurados deben contar con tarjetas de etiquetado (SKU 0001177) que identifiquen al responsable, motivo y fecha estimada de finalización.</li>
        <li>Conforme a la Norma RETIE, la instalación en tableros eléctricos debe ser realizada por un Técnico Eléctrico con certificación CONTE.</li>
        <li>ASSA ABLOY COLOMBIA ofrece programas de capacitación práctica en control de energías peligrosas, sin costo, previa coordinación.</li>
        <li>El código de colores de candados debe ser definido según el programa LOTO interno y aplicado consistentemente.</li>
      </ol>
    </div>

    <!-- Nota comercial -->
    <% if (informe.notas_comerciales) { %>
    <div class="report-notes" style="border-top:1px solid #e5e5e5;">
      <h3 style="color:#333;">NOTA COMERCIAL</h3>
      <p style="font-size:0.78rem;color:#333;"><%= informe.notas_comerciales %></p>
    </div>
    <% } %>

    <!-- Firma -->
    <div class="report-signature">
      <p>Agradecemos la confianza depositada en <strong>ASSA ABLOY COLOMBIA</strong> y quedamos atentos a cualquier requerimiento adicional.</p>
      <br><p>Saludos Cordiales.</p><br><br>
      <p><strong><%= informe.ejecutivo || user.nombre %></strong></p>
      <p>Ejecutivo Comercial <%= informe.zona || user.zona || '' %></p>
      <p><strong>ASSA ABLOY COLOMBIA S.A.S.</strong></p>
      <p>Calle 12 N° 32-39, Bogotá D.C., Colombia — Teléfono: +601 5962000</p>
    </div>

    <!-- Footer -->
    <div class="report-footer">
      <p>© <%= anioActual %> ASSA ABLOY Colombia S.A.S. — Yale LOTO Solutions</p>
      <span class="report-confidential">Documento Confidencial</span>
    </div>

  </div><!-- /report-page -->
</main>

<style>
@media print {
  .no-print, .navbar, .app-footer { display: none !important; }
  .page-content { padding: 0 !important; }
  .report-page { box-shadow: none !important; border-radius: 0 !important; }
}
</style>


<!-- ══ MODAL ENVÍO POR CORREO ══════════════════════════════════════════════ -->
<div id="modal-envio" class="send-modal-overlay">
  <div class="send-modal-box">

    <!-- Header -->
    <div class="send-modal-header">
      <div class="send-modal-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </div>
      <div>
        <h2 class="send-modal-title">Enviar Informe</h2>
        <p class="send-modal-sub"><%= informe.empresa || 'Sin cliente' %> · <%= hallazgos.length %> puntos de bloqueo</p>
      </div>
      <button class="send-modal-close" onclick="cerrarModalEnvio()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Info del PDF -->
    <div class="send-pdf-info">
      <div class="send-pdf-icon"></div>
      <div>
        <div class="send-pdf-name">Informe_LOTO_<%= (informe.empresa||'Cliente').replace(/\s+/g,'_') %>_<%= new Date().toISOString().split('T')[0] %>.pdf</div>
        <div class="send-pdf-sub">Se generará y adjuntará automáticamente al correo</div>
      </div>
    </div>

    <!-- Formulario -->
    <form id="form-envio" class="send-form">
      <div class="form-group">
        <label class="form-label">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:4px"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Correo del destinatario *
        </label>
        <input type="email" id="email-destino" name="email_destino" class="form-input"
               placeholder="cliente@empresa.com" required
               value="<%= informe.email || '' %>">
      </div>
      <div class="form-group">
        <label class="form-label">Con copia (CC) — opcional</label>
        <input type="email" id="email-cc" name="email_cc" class="form-input"
               placeholder="gerencia@empresa.com">
      </div>
      <div class="form-group">
        <label class="form-label">Mensaje personal — opcional</label>
        <textarea id="mensaje-personal" name="mensaje_personal" class="form-input"
                  rows="3" placeholder="Ej: Estimados, adjunto el informe de la visita realizada..."></textarea>
      </div>

      <!-- Estado del envío -->
      <div id="send-status" class="send-status" style="display:none;"></div>

      <!-- Botones -->
      <div class="send-actions">
        <button type="button" class="btn btn-outline" onclick="cerrarModalEnvio()">Cancelar</button>
        <button type="submit" class="btn btn-send" id="btn-send-submit">
          <span id="btn-send-text">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:5px"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar informe
          </span>
          <span id="btn-send-loading" style="display:none;">
            <span class="send-spinner"></span> Generando PDF...
          </span>
        </button>
      </div>
    </form>

  </div>
</div>

<script>
function abrirModalEnvio() {
  document.getElementById('modal-envio').classList.add('send-modal-open');
  document.body.style.overflow = 'hidden';
}
function cerrarModalEnvio() {
  document.getElementById('modal-envio').classList.remove('send-modal-open');
  document.body.style.overflow = '';
  document.getElementById('send-status').style.display = 'none';
  document.getElementById('form-envio').reset();
  resetSendBtn();
}
function resetSendBtn() {
  document.getElementById('btn-send-text').style.display    = '';
  document.getElementById('btn-send-loading').style.display = 'none';
  document.getElementById('btn-send-submit').disabled       = false;
}

// Cerrar con Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') cerrarModalEnvio();
});

// Submit AJAX
document.getElementById('form-envio').addEventListener('submit', async e => {
  e.preventDefault();

  const btn     = document.getElementById('btn-send-submit');
  const status  = document.getElementById('send-status');
  const loading = document.getElementById('btn-send-loading');
  const text    = document.getElementById('btn-send-text');

  btn.disabled        = true;
  text.style.display  = 'none';
  loading.style.display = '';
  loading.querySelector('span.send-spinner') && (loading.querySelector('span').textContent = 'Generando PDF...');
  status.style.display = 'none';

  try {
    const body = new URLSearchParams({
      email_destino:    document.getElementById('email-destino').value,
      email_cc:         document.getElementById('email-cc').value,
      mensaje_personal: document.getElementById('mensaje-personal').value,
    });

    // Actualizar texto mientras espera
    setTimeout(() => {
      if (btn.disabled) loading.innerHTML = '<span class="send-spinner"></span> Enviando correo...';
    }, 3000);

    const res  = await fetch('/informes/<%= informe.id %>/enviar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body,
    });
    const data = await res.json();

    if (data.ok) {
      status.className   = 'send-status send-status-ok';
      status.innerHTML   = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> ${data.mensaje}`;
      status.style.display = 'flex';
      resetSendBtn();
      // Actualizar badge de estado en la página
      const badge = document.querySelector('.ic-estado');
      if (badge) { badge.textContent = 'enviado'; badge.className = 'ic-estado ic-estado-enviado'; }
      setTimeout(() => cerrarModalEnvio(), 3500);
    } else {
      throw new Error(data.error || 'Error desconocido');
    }
  } catch (err) {
    status.className   = 'send-status send-status-err';
    status.innerHTML   = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg> ${err.message}`;
    status.style.display = 'flex';
    resetSendBtn();
  }
});
</script>

<style>
/* ── Botón enviar ── */
.btn-send {
  background: #1A1A1A;
  color: #F5C800;
  border: 2px solid #1A1A1A;
  display: inline-flex; align-items: center;
  padding: 8px 18px; border-radius: 4px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 800; font-size: .78rem;
  letter-spacing: .5px; cursor: pointer;
  text-decoration: none; transition: all .15s;
  white-space: nowrap;
}
.btn-send:hover { background: #2e2e2e; border-color: #2e2e2e; }

/* ── Modal overlay ── */
.send-modal-overlay {
  display: none;
  position: fixed; inset: 0; z-index: 8000;
  align-items: center; justify-content: center;
  padding: 1rem;
  background: rgba(0,0,0,0.55);
  backdrop-filter: blur(3px);
}
.send-modal-overlay.send-modal-open { display: flex; }

/* ── Modal box ── */
.send-modal-box {
  background: #fff;
  border-radius: 12px;
  width: 100%; max-width: 480px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.28);
  overflow: hidden;
  animation: modalIn .28s cubic-bezier(.34,1.56,.64,1);
  border-top: 4px solid #F5C800;
}

/* ── Modal header ── */
.send-modal-header {
  background: #1A1A1A;
  padding: 16px 20px;
  display: flex; align-items: center; gap: .75rem;
}
.send-modal-icon {
  width: 40px; height: 40px; border-radius: 50%;
  background: rgba(245,200,0,.15);
  display: flex; align-items: center; justify-content: center;
  color: #F5C800; flex-shrink: 0;
}
.send-modal-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.3rem; letter-spacing: 2px; color: #fff; line-height: 1;
}
.send-modal-sub  { font-size: .65rem; color: rgba(255,255,255,.5); margin-top: 2px; }
.send-modal-close {
  margin-left: auto; background: none; border: none;
  color: rgba(255,255,255,.4); cursor: pointer;
  padding: 4px; transition: color .15s;
  display: flex; align-items: center;
}
.send-modal-close:hover { color: #fff; }

/* ── PDF info strip ── */
.send-pdf-info {
  background: #FFFBE6;
  border-bottom: 1px solid #F5C800;
  padding: 12px 20px;
  display: flex; align-items: center; gap: .75rem;
}
.send-pdf-icon  { font-size: 1.6rem; flex-shrink: 0; }
.send-pdf-name  { font-size: .75rem; font-weight: 700; color: #1A1A1A; }
.send-pdf-sub   { font-size: .65rem; color: #888; margin-top: 2px; }

/* ── Form area ── */
.send-form { padding: 20px; display: flex; flex-direction: column; gap: .85rem; }

/* ── Status ── */
.send-status {
  display: flex; align-items: center; gap: .5rem;
  padding: 10px 14px; border-radius: 6px;
  font-size: .78rem; font-weight: 600;
}
.send-status-ok  { background: #E8F5E9; color: #1B5E20; border: 1px solid #A5D6A7; }
.send-status-err { background: #FFEBEE; color: #B71C1C; border: 1px solid #FFCDD2; }

/* ── Actions ── */
.send-actions { display: flex; justify-content: flex-end; gap: .6rem; padding-top: .4rem; }

/* ── Spinner ── */
.send-spinner {
  display: inline-block; width: 14px; height: 14px;
  border: 2px solid rgba(245,200,0,.3);
  border-top-color: #F5C800;
  border-radius: 50%;
  animation: spin .7s linear infinite;
  margin-right: 6px; vertical-align: middle;
}
@keyframes spin { to { transform: rotate(360deg); } }

@media print { #modal-envio { display: none !important; } }
</style>

<%- include('../partials/footer') %>
